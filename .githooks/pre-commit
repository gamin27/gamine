#!/bin/sh
set -eu

cd "$(git rev-parse --show-toplevel)"

run_script() {
	script="$1"

	if command -v npm >/dev/null 2>&1; then
		npm run "$script"
		return
	fi

	if ! command -v node >/dev/null 2>&1; then
		echo "pre-commit: npm or node is required to run checks." >&2
		exit 1
	fi

	case "$script" in
		lint)
			node ./node_modules/.bin/eslint .
			;;
		format)
			node ./node_modules/.bin/prettier --write .
			;;
		format:check)
			node ./node_modules/.bin/prettier --check .
			;;
		*)
			echo "pre-commit: unknown script: $script" >&2
			exit 1
			;;
	esac
}

format_staged() {
	files="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(astro|css|html|js|jsx|json|md|mdx|mjs|cjs|ts|tsx|yaml|yml)$' || true)"

	if [ -z "$files" ]; then
		return
	fi

	if command -v npm >/dev/null 2>&1; then
		printf '%s\n' "$files" | xargs npm exec -- prettier --write
	else
		printf '%s\n' "$files" | xargs node ./node_modules/.bin/prettier --write
	fi

	printf '%s\n' "$files" | xargs git add
}

format_staged
run_script lint
run_script format:check
