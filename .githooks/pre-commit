#!/bin/sh
set -eu

cd "$(git rev-parse --show-toplevel)"

run_script() {
	script="$1"

	if command -v npm >/dev/null 2>&1; then
		npm run "$script"
		return
	fi

	if ! command -v node >/dev/null 2>&1; then
		echo "pre-commit: npm or node is required to run checks." >&2
		exit 1
	fi

	case "$script" in
		lint)
			node ./node_modules/.bin/eslint .
			;;
		format:check)
			node ./node_modules/.bin/prettier --check .
			;;
		*)
			echo "pre-commit: unknown script: $script" >&2
			exit 1
			;;
	esac
}

run_script lint
run_script format:check
