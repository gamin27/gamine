---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Main from '../../components/Main.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`フェードインアニメーションのデモ | ${SITE_TITLE}`}
			description="フェードインアニメーションのデモ画面"
		/>
		<style>
			.demo-content {
				display: grid;
				gap: 32px;
				animation: demo-fade-in 180ms ease-out both;
			}
			@keyframes demo-fade-in {
				from {
					opacity: 0;
					transform: translateY(32px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			.demo-heading {
				display: grid;
				gap: 12px;
			}
			.demo-heading h1 {
				margin: 0;
				font-size: 32px;
				line-height: 1.4;
			}
			.demo-heading p,
			.demo-section p {
				margin: 0;
				font-weight: 700;
				line-height: 1.9;
			}
			.demo-section {
				display: grid;
				gap: 16px;
			}
			.demo-section h2 {
				margin: 0;
				font-size: 24px;
			}
			.demo-list {
				display: grid;
				gap: 12px;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.demo-list li {
				padding-bottom: 12px;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			@media (max-width: 720px) {
				.demo-heading h1 {
					font-size: 24px;
				}
				.demo-section h2 {
					font-size: 20px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<Main>
			<section class="demo-content">
				<div class="demo-heading">
					<h1>フェードインアニメーションのデモ</h1>
					<p>本文全体が少し下からふわっと現れます。</p>
				</div>
				<section class="demo-section">
					<h2>記事の見出し</h2>
					<p>
						単体では控えめでも、ページを移動するたびに本文が遅れて見えると、読み込みの点滅のように感じられます。
					</p>
				</section>
				<ul class="demo-list">
					<li>短い演出でも、読み始めの一瞬を遅らせてしまう。</li>
					<li>記事ページでは本文量や目次の描画と重なり、ちらつきに見えることがある。</li>
					<li>静かなブログでは、何もしない方がブランドに合う場合がある。</li>
				</ul>
			</section>
		</Main>
		<Footer />
	</body>
</html>
