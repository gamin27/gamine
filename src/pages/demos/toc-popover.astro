---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Main from '../../components/Main.astro';
import { SITE_TITLE } from '../../consts';

const sections = [
	{
		id: 'tone',
		title: '静かな動き',
		body: '目次は記事の上に重なって表示されます。記事自体は動かないため、構造は素直で、標準の開閉挙動をそのまま使えます。',
	},
	{
		id: 'native',
		title: '標準のふるまい',
		body: 'popover は外側のタップや Escape キーで閉じる動作をブラウザが担います。レイヤー管理も単純で、実装の見通しはよくなります。',
	},
	{
		id: 'tradeoff',
		title: '見た目の違い',
		body: '一方で、目次が記事の下に潜んでいる感覚は弱くなります。操作は自然ですが、今のスライド表現よりも一般的なメニューに近い印象になります。',
	},
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`popover目次のデモ | ${SITE_TITLE}`}
			description="popoverを使ったモバイル目次のデモ画面"
		/>
		<style>
			.demo-article {
				display: grid;
				gap: 40px;
			}
			.demo-title {
				display: grid;
				gap: 8px;
			}
			.demo-title h1 {
				margin: 0;
				font-size: 32px;
				line-height: 1.4;
			}
			.demo-title p,
			.demo-section p {
				margin: 0;
				font-weight: 700;
				line-height: 1.9;
			}
			.demo-section {
				display: grid;
				gap: 16px;
			}
			.demo-section h2 {
				margin: 0;
				padding-bottom: 8px;
				border-bottom: 1px solid rgba(var(--gray), 0.35);
				font-size: 24px;
				scroll-margin-top: 112px;
			}
			.toc-button {
				position: fixed;
				right: 16px;
				bottom: calc(24px + env(safe-area-inset-bottom));
				z-index: 10;
				display: grid;
				place-items: center;
				width: 48px;
				height: 48px;
				padding: 0;
				border: 1px solid rgba(var(--gray), 0.24);
				border-radius: 8px;
				background: var(--bg);
				color: rgb(var(--gray-dark));
				box-shadow: 0 4px 12px rgba(var(--gray), 0.12);
				cursor: pointer;
			}
			.toc-button svg {
				width: 22px;
				height: 22px;
				fill: none;
				stroke: currentColor;
				stroke-linecap: round;
				stroke-linejoin: round;
				stroke-width: 2;
			}
			.toc-button-close {
				display: none;
			}
			body:has(#toc-popover:popover-open) .toc-button-open {
				display: none;
			}
			body:has(#toc-popover:popover-open) .toc-button-close {
				display: block;
			}
			.toc-popover {
				inset: 0 auto 0 0;
				width: min(80vw, 320px);
				height: 100dvh;
				max-height: none;
				box-sizing: border-box;
				margin: 0;
				padding: 24px 20px;
				border: 0;
				border-radius: 0;
				background: var(--brand);
				color: var(--bg);
				box-shadow: 12px 0 32px rgba(var(--gray-dark), 0.28);
				transform: translateX(-100%);
				transition:
					transform 0.32s ease,
					overlay 0.32s ease allow-discrete,
					display 0.32s ease allow-discrete;
			}
			.toc-popover:popover-open {
				transform: translateX(0);
			}
			@starting-style {
				.toc-popover:popover-open {
					transform: translateX(-100%);
				}
			}
			.toc-popover nav {
				display: grid;
				gap: 16px;
				font-weight: 700;
			}
			.toc-heading {
				display: inline-flex;
				align-items: center;
				gap: 12px;
				margin: 0;
				color: var(--bg);
				font-size: 16px;
				line-height: 1.4;
			}
			.toc-heading svg {
				width: 18px;
				height: 18px;
				fill: none;
				stroke: currentColor;
				stroke-linecap: round;
				stroke-linejoin: round;
				stroke-width: 2;
			}
			.toc-popover ol {
				display: grid;
				gap: 8px;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.toc-popover a {
				display: block;
				border-radius: 4px;
				color: var(--bg);
				font-size: 14px;
				line-height: 1.5;
				text-decoration: none;
			}
			.toc-popover a:hover {
				background-color: rgba(250, 248, 241, 0.16);
				box-shadow: 0 0 0 4px rgba(250, 248, 241, 0.16);
			}
			@media (max-width: 720px) {
				.demo-title h1 {
					font-size: 24px;
				}
				.demo-section h2 {
					font-size: 22px;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.toc-popover {
					transition: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<Main>
			<article class="demo-article">
				<div class="demo-title">
					<h1>popover目次のデモ</h1>
					<p>標準の popover を使うと、目次は記事の上に静かに重なるUIとして扱えます。</p>
				</div>
				{
					sections.map((section) => (
						<section class="demo-section">
							<h2 id={section.id}>{section.title}</h2>
							<p>{section.body}</p>
						</section>
					))
				}
			</article>
		</Main>
		<Footer />
		<button class="toc-button" type="button" aria-label="目次を開く" popovertarget="toc-popover">
			<svg class="toc-button-open" viewBox="0 0 24 24" aria-hidden="true">
				<path d="M4 6h16"></path>
				<path d="M4 12h16"></path>
				<path d="M4 18h10"></path>
			</svg>
			<svg class="toc-button-close" viewBox="0 0 24 24" aria-hidden="true">
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
		</button>
		<div class="toc-popover" id="toc-popover" popover>
			<nav aria-label="目次">
				<h2 class="toc-heading">
					<span>目次</span>
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="m6 9 6 6 6-6"></path>
					</svg>
				</h2>
				<ol>
					{
						sections.map((section) => (
							<li>
								<a href={`#${section.id}`}>{section.title}</a>
							</li>
						))
					}
				</ol>
			</nav>
		</div>
	</body>
</html>
