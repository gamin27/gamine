---
import { parse } from 'astro:schema';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Main from '../components/Main.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const features =
	'要件を理解し、構造を把握してUIに落とし込むこと。正しいものを正しく作ること。デザインシステム・Storybookと連携し、AIエージェントによるUI設計の仕組み化に注力していきたいです。';

const careers = [
	{
		period: ['2021年1月 -', '現在'],
		company: 'iCARE',
		role: 'フロントエンドエンジニア',
		details: [
			{
				term: '担当',
				description: 'フロントエンドエンジニア',
			},
			{
				term: '技術',
				description:
					'Vue.js (Composition API) + GraphQL (Apollo) + Buefy + Storybook + zod + TypeScript',
			},
			{
				term: '活動',
				description:
					'フロントエンドどUIデザインをつなぎ、Figma, Design System, Storybookを活用して、UIの品質向上と開発効率化に取り組んでいます。',
			},
		],
	},
	{
		period: ['2017年4月 -', '2020年3月'],
		company: '住友電工情報システム',
		role: 'プログラマー',
		details: [
			{
				term: '概要',
				description: '設計システムの改修・保守を担当',
			},
			{
				term: 'チーム規模',
				description: '8人前後',
			},
			{
				term: '担当',
				description: 'PG (内部設計からリリース)、ユーザヒアリング',
			},
			{
				term: '開発手法',
				description: 'ウォーターフォール開発',
			},
			{
				term: '技術',
				description: 'Apache Tomcat + OracleDB + Java + Servlet/JSP',
			},
		],
	},
	{
		period: ['2021年4月 -', '2017年3月'],
		company: '福井大学大学院 University of Fukui',
		role: '情報・メディア工学専攻',
		details: [
			{
				term: '研究タイトル',
				description:
					'実行時の動的かつ頻繁なグループ変更に対応可能な MPI 環境下でのマルチキャストの実装',
			},
			{
				term: '研究内容',
				description:
					'MPI では集団通信手法としてブロードキャスト(一対全通信)のメカニズムが提供されており,あらかじめ指定したグループに属す全てのノードにブロードキャ ストする機能を利用してマルチキャストを実装することが可能である. しかしながら, 各ワーカーノードは自分がどのグループに所属するかの情報が実行前に既知である必要があり, 実行時にグループ構成が確定しかつ頻繁にその構成が変動する環境下でのマルチキャストへの応用ができない.このようなMPIを用いたマスター・ワー カー型の大規模並列処理環境下で, 実行時の動的かつ頻繁なグループ変更に対応可能な動的マルチキャスト機構を実装した。※FIT2016論文賞受賞(https://www.ipsj.or.jp/award/9faeag0000004f1r-att/a1475478293440.pdf)',
			},
		],
	},
];
---

<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.about {
				display: grid;
				gap: 56px;
			}
			.hero {
				max-width: 760px;
			}
			.period {
				margin-bottom: 8px;
				color: rgb(var(--gray));
				font-size: 16px;
				font-weight: 700;
				line-height: 1.5;
			}
			.period span {
				white-space: nowrap;
			}
			.period span + span::before {
				content: ' ';
			}
			.hero-content h1 {
				margin: 0 0 24px;
				color: rgb(var(--black));
				font-size: 32px;
				line-height: 1.4;
			}
			.hero-content p {
				margin: 0;
				font-size: 20px;
				font-weight: 700;
				line-height: 2;
			}
			.timeline {
				display: grid;
				gap: 56px;
			}
			.timeline-item {
				display: grid;
				grid-template-columns: 8px minmax(0, 1fr);
				gap: 24px;
				position: relative;
			}
			.timeline-item::before {
				position: absolute;
				top: 24px;
				bottom: -56px;
				left: 3px;
				width: 2px;
				background: var(--brand);
				content: '';
			}
			.timeline-item:last-child::before {
				display: none;
			}
			.marker {
				width: 8px;
				height: 8px;
				margin-top: 8px;
				border-radius: 50%;
				background: var(--brand);
			}
			.career h2 {
				margin: 0 0 4px;
				color: rgb(var(--black));
				font-size: 28px;
				line-height: 1.4;
			}
			.role {
				margin: 0 0 18px;
				color: rgb(var(--black));
				font-size: 18px;
				font-weight: 700;
			}
			.details {
				display: grid;
				gap: 6px;
				margin: 0;
				font-size: 18px;
				font-weight: 700;
				line-height: 1.7;
			}
			.details-row {
				display: grid;
				grid-template-columns: max-content minmax(0, 1fr);
				column-gap: 0.35em;
			}
			.details dt::after {
				content: '：';
			}
			.details dd {
				margin: 0;
			}
			@media (max-width: 560px) {
				.about {
					gap: 40px;
				}
				.hero {
					margin-left: 0;
				}
				.hero-content h1 {
					font-size: 28px;
				}
				.hero-content p {
					font-size: 18px;
					line-height: 1.8;
				}
				.timeline {
					gap: 40px;
				}
				.career h2 {
					font-size: 24px;
				}
				.details-row {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<Main width="960px">
			<section class="about">
				<div class="hero">
					<div class="hero-content">
						<h1>この先やってみたいこと</h1>
						<p>
							{features}
						</p>
					</div>
				</div>

				<div class="timeline" aria-label="職歴">
					{
						careers.map((career) => (
							<section class="timeline-item">
								<div class="marker" aria-hidden="true" />
								<div class="career">
									<div class="period">
										{career.period.map((line) => (
											<span>{line}</span>
										))}
									</div>
									<h2>{career.company}</h2>
									<p class="role">{career.role}</p>
									<dl class="details">
										{career.details.map((detail) => (
											<div class="details-row">
												<dt>{detail.term}</dt>
												<dd>
													{detail.description.split(/(https?:\/\/[^\s)）]+)/g).map((part) =>
														/^https?:\/\//.test(part) ? (
															<a href={part} target="_blank" rel="noopener noreferrer">
																{part}
															</a>
														) : (
															part
														),
													)}
												</dd>
											</div>
										))}
									</dl>
								</div>
							</section>
						))
					}
				</div>
			</section>
		</Main>
		<Footer />
	</body>
</html>
