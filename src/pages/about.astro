---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Main from '../components/Main.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const features =
	'要件を理解し、構造を把握してUIに落とし込むこと。正しいものを正しく作ること。デザインシステム・Storybookと連携し、AIエージェントによるUI設計を仕組み化すること。';

const summaries = [
	{
		title: '取り組んでいること',
		items: [
			'フロントエンドとUIデザインの橋渡し',
			'Figma, Design System, Storybookを活用したUI品質の向上',
			'AIエージェントによるUI設計・実装フローの仕組み化',
		],
	},
	{
		title: '興味があること',
		items: [
			'プロダクトの要件を整理し、使いやすい画面へ落とし込むこと',
			'デザインシステムとコンポーネント設計',
			'Astroのような静的サイトジェネレータでの、表現と性能の両立',
		],
	},
];

const careers = [
	{
		period: ['2021年1月 -', '現在'],
		company: 'iCARE',
		role: 'フロントエンドエンジニア',
		details: [
			{
				term: '担当',
				description: 'フロントエンドエンジニア',
			},
			{
				term: '技術',
				description:
					'Vue.js (Composition API) + GraphQL (Apollo) + Buefy + Storybook + zod + TypeScript',
			},
			{
				term: '活動',
				description:
					'フロントエンドとUIデザインをつなぎ、Figma, Design System, Storybookを活用して、UIの品質向上と開発効率化に取り組んでいます。',
			},
		],
	},
	{
		period: ['2017年4月 -', '2020年3月'],
		company: '住友電工情報システム',
		role: 'プログラマー',
		details: [
			{
				term: '概要',
				description: '設計システムの改修・保守を担当',
			},
			{
				term: 'チーム規模',
				description: '8人前後',
			},
			{
				term: '担当',
				description: 'PG (内部設計からリリース)、ユーザヒアリング',
			},
			{
				term: '開発手法',
				description: 'ウォーターフォール開発',
			},
			{
				term: '技術',
				description: 'Apache Tomcat + OracleDB + Java + Servlet/JSP',
			},
		],
	},
	{
		period: [' -', '2017年3月'],
		company: '福井大学大学院 University of Fukui',
		role: '情報・メディア工学専攻',
		details: [
			{
				term: '研究タイトル',
				description:
					'実行時の動的かつ頻繁なグループ変更に対応可能な MPI 環境下でのマルチキャストの実装',
			},
			{
				term: '研究内容',
				description:
					'※FIT2016論文賞受賞(https://www.ipsj.or.jp/award/9faeag0000004f1r-att/a1475478293440.pdf)',
			},
		],
	},
];
---

<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.about {
				display: grid;
				gap: 56px;
			}
			.profile {
				display: flex;
				align-items: center;
				gap: 0.4em;
				font-size: 32px;
			}
			.profile-heading {
				display: grid;
				gap: 12px;
			}
			.profile-icon {
				width: 64px;
				height: 64px;
				border-radius: 50%;
				background: #fff;
				object-fit: cover;
			}
			.profile h1 {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1em;
				line-height: 1.2;
			}
			.profile-description {
				margin: 0;
				max-width: 760px;
				color: rgb(var(--black));
				font-size: 20px;
				font-weight: 700;
				line-height: 1.8;
			}
			.hero {
				max-width: 760px;
			}
			.period {
				margin-bottom: 8px;
				color: rgb(var(--gray));
				font-size: 16px;
				font-weight: 700;
				line-height: 1.5;
			}
			.period span {
				white-space: nowrap;
			}
			.period span + span::before {
				content: ' ';
			}
			.hero-content h2 {
				margin: 0 0 24px;
				color: rgb(var(--black));
				font-size: 24px;
				line-height: 1.4;
			}
			.hero-content p {
				margin: 0;
				font-size: 20px;
				font-weight: 700;
				line-height: 2;
			}
			.about-summary {
				display: grid;
				gap: 32px;
			}
			.summary-group {
				min-width: 0;
			}
			.summary-group h2 {
				margin: 0 0 16px;
				color: rgb(var(--black));
				font-size: 22px;
				line-height: 1.4;
			}
			.summary-list {
				display: grid;
				gap: 10px;
				margin: 0;
				padding: 0;
				list-style: none;
				font-size: 17px;
				font-weight: 700;
				line-height: 1.7;
			}
			.summary-list li {
				position: relative;
				padding-left: 18px;
				overflow-wrap: anywhere;
			}
			.summary-list li::before {
				position: absolute;
				top: 0.78em;
				left: 0;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--brand);
				content: '';
			}
			.timeline {
				display: grid;
				gap: 56px;
			}
			.timeline-item {
				display: grid;
				grid-template-columns: 8px minmax(0, 1fr);
				gap: 24px;
				position: relative;
			}
			.timeline-item::before {
				position: absolute;
				top: 24px;
				bottom: -56px;
				left: 3px;
				width: 2px;
				background: var(--brand);
				content: '';
			}
			.timeline-item:last-child::before {
				display: none;
			}
			.marker {
				width: 8px;
				height: 8px;
				margin-top: 8px;
				border-radius: 50%;
				background: var(--brand);
			}
			.timeline-section {
				display: grid;
				gap: 24px;
			}
			.timeline-title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 24px;
				line-height: 1.4;
			}
			.career h3 {
				margin: 0 0 4px;
				color: rgb(var(--black));
				font-size: 28px;
				line-height: 1.4;
			}
			.career,
			.details-row,
			.details dd {
				min-width: 0;
			}
			.role {
				margin: 0 0 18px;
				color: rgb(var(--black));
				font-size: 18px;
				font-weight: 700;
			}
			.details {
				display: grid;
				gap: 6px;
				margin: 0;
				font-size: 18px;
				font-weight: 700;
				line-height: 1.7;
			}
			.details-row {
				display: grid;
				grid-template-columns: max-content minmax(0, 1fr);
				column-gap: 0.35em;
			}
			.details dt::after {
				content: '：';
			}
			.details dd {
				margin: 0;
				overflow-wrap: anywhere;
				word-break: break-word;
			}
			.details a {
				color: rgb(var(--gray));
				overflow-wrap: anywhere;
				word-break: break-word;
			}
			.details a:hover {
				color: rgb(var(--black));
			}
			@media (max-width: 560px) {
				.about {
					gap: 40px;
				}
				.profile {
					font-size: 28px;
				}
				.profile-description {
					font-size: 18px;
				}
				.hero {
					margin-left: 0;
				}
				.hero-content h2 {
					font-size: 22px;
				}
				.hero-content p {
					font-size: 18px;
					line-height: 1.8;
				}
				.summary-group h2 {
					font-size: 20px;
				}
				.summary-list {
					font-size: 16px;
				}
				.timeline {
					gap: 40px;
				}
				.timeline-item::before {
					bottom: -40px;
				}
				.career h3 {
					font-size: 24px;
				}
				.timeline-title {
					font-size: 22px;
				}
				.details-row {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<Main width="960px">
			<section class="about">
				<div class="profile-heading">
					<div class="profile">
						<img class="profile-icon" src="/favicon.png" alt="" />
						<h1>gamine</h1>
					</div>
					<p class="profile-description">
						デザインエンジニアっぽいフロントエンドエンジニア。なぜこのUIなのかを言語化し、仕組み化します。
					</p>
				</div>

				<section class="about-summary" aria-label="いまの関心">
					{
						summaries.map((summary) => (
							<section class="summary-group">
								<h2>{summary.title}</h2>
								<ul class="summary-list">
									{summary.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
							</section>
						))
					}
				</section>

				<div class="hero">
					<div class="hero-content">
						<h2>この先やってみたいこと</h2>
						<p>
							{features}
						</p>
					</div>
				</div>

				<section class="timeline-section" aria-labelledby="timeline-title">
					<h2 id="timeline-title" class="timeline-title">経歴</h2>
					<div class="timeline">
						{
							careers.map((career) => (
								<section class="timeline-item">
									<div class="marker" aria-hidden="true" />
									<div class="career">
										<div class="period">
											{career.period.map((line) => (
												<span>{line}</span>
											))}
										</div>
										<h3>{career.company}</h3>
										<p class="role">{career.role}</p>
										<dl class="details">
											{career.details.map((detail) => (
												<div class="details-row">
													<dt>{detail.term}</dt>
													<dd>
														{detail.description.split(/(https?:\/\/[^\s)）]+)/g).map((part) =>
															/^https?:\/\//.test(part) ? (
																<a href={part} target="_blank" rel="noopener noreferrer">
																	{part}
																</a>
															) : (
																part
															),
														)}
													</dd>
												</div>
											))}
										</dl>
									</div>
								</section>
							))
						}
					</div>
				</section>
			</section>
		</Main>
		<Footer />
	</body>
</html>
