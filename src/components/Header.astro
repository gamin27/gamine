---
import HeaderNavItem from './HeaderNavItem.astro';

const normalizedPathname = Astro.url.pathname
	.replace(import.meta.env.BASE_URL, '/')
	.replace(/\/$/, '');
const pathname = normalizedPathname.startsWith('/')
	? normalizedPathname || '/'
	: `/${normalizedPathname}`;

const links = [
	{
		href: '/',
		label: 'Blog',
		activePaths: ['/', '/blog'],
	},
	{
		href: '/tags',
		label: 'Tags',
		activePaths: ['/tags'],
	},
	{
		href: '/search',
		label: 'Search',
		activePaths: ['/search'],
	},
	{
		href: '/about',
		label: 'About',
		activePaths: ['/about'],
	},
];

const isActive = (activePaths: string[]) =>
	activePaths.some(
		(path) => pathname === path || (path !== '/' && pathname.startsWith(`${path}/`)),
	);
---

<header data-site-header>
	<div class="header-inner">
		<div class="brand-row">
			<a class="brand" href="/">gamine.blog</a>
		</div>
		<nav class="header-nav">
			{
				links.map((link) => (
					<HeaderNavItem href={link.href} label={link.label} active={isActive(link.activePaths)} />
				))
			}
		</nav>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: -48px;
		z-index: 10;
		margin: 0;
		background: var(--bg);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.header-inner {
		display: flex;
		flex-direction: column;
		width: min(100% - 64px, 1120px);
		margin: 0 auto;
	}
	.brand-row {
		display: flex;
		align-items: center;
		padding: 16px 0 8px;
	}
	.brand {
		color: var(--brand);
		font-size: 24px;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
	}
	.header-nav {
		display: flex;
		align-items: stretch;
		justify-content: flex-start;
		overflow-x: auto;
	}
	@media (max-width: 720px) {
		.brand-row {
			padding-top: 14px;
			padding-bottom: 10px;
		}
		.header-nav {
			min-width: 0;
			min-height: 3.75rem;
		}
	}
</style>
