---
type Heading = {
	depth: number;
	slug: string;
	text: string;
};

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2);
---

{
	tocHeadings.length > 0 && (
		<nav class="toc" aria-label="目次" data-pagefind-ignore>
			<details open>
				<summary>
					<svg class="toc-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M4 7h16M4 12h12M4 17h8" />
					</svg>
					<span>目次</span>
					<svg class="toc-chevron" viewBox="0 0 24 24" aria-hidden="true">
						<path d="m6 9 6 6 6-6" />
					</svg>
				</summary>
				<ol>
					{tocHeadings.map((heading, index) => (
						<li>
							<a href={`#${heading.slug}`} class:list={{ 'is-active': index === 0 }}>
								{heading.text}
							</a>
						</li>
					))}
				</ol>
			</details>
		</nav>
	)
}

<script>
	const tocLinks = Array.from<HTMLAnchorElement>(document.querySelectorAll('.toc a'));
	const targetHeadings = tocLinks
		.map((link) => {
			const id = decodeURIComponent(link.hash.slice(1));
			return document.getElementById(id);
		})
		.filter((heading): heading is HTMLElement => heading !== null);

	const setActiveLink = (id: string) => {
		tocLinks.forEach((link) => {
			link.classList.toggle('is-active', decodeURIComponent(link.hash.slice(1)) === id);
		});
	};

	tocLinks.forEach((link) => {
		link.addEventListener('click', () => {
			setActiveLink(decodeURIComponent(link.hash.slice(1)));
		});
	});

	if (targetHeadings.length > 0) {
		const visibleHeadings = new Map<string, number>();
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const id = entry.target.id;

					if (entry.isIntersecting) {
						visibleHeadings.set(id, entry.boundingClientRect.top);
					} else {
						visibleHeadings.delete(id);
					}
				});

				const activeId = Array.from(visibleHeadings)
					.sort(([, topA], [, topB]) => topA - topB)
					.at(0)?.[0];

				if (activeId) {
					setActiveLink(activeId);
				}
			},
			{
				rootMargin: '-20% 0px -65% 0px',
				threshold: 0,
			},
		);

		targetHeadings.forEach((heading) => observer.observe(heading));
	}
</script>

<style>
	.toc {
		color: rgb(var(--gray-dark));
		font-weight: 700;
	}
	summary {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
		color: rgb(var(--gray-dark));
		font-size: 22px;
		line-height: 1.4;
		cursor: pointer;
		list-style: none;
	}
	summary::-webkit-details-marker {
		display: none;
	}
	.toc-icon,
	.toc-chevron {
		width: 22px;
		height: 22px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}
	.toc-chevron {
		width: 18px;
		height: 18px;
		transition: transform var(--transition-hover);
	}
	details:not([open]) .toc-chevron {
		transform: rotate(-90deg);
	}
	ol {
		display: grid;
		gap: 8px;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	a {
		display: block;
		border-radius: 4px;
		color: rgb(var(--gray-dark));
		font-size: 14px;
		line-height: 1.5;
		text-decoration: none;
		transition:
			background-color var(--transition-hover),
			box-shadow var(--transition-hover),
			color var(--transition-hover);
	}
	a:hover {
		background-color: #ededed;
		box-shadow: 0 0 0 4px #ededed;
		color: rgb(var(--gray-dark));
	}
	a.is-active {
		color: var(--brand);
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}
	@media (max-width: 960px) {
		summary {
			margin-bottom: 20px;
			font-size: 20px;
		}
	}
</style>
