---
import Tooltip from './Tooltip.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
const tooltipId = 'share-copy-tooltip';
const shareURL = new URL(Astro.url.pathname, Astro.site);
const xShareURL = `https://x.com/intent/tweet?${new URLSearchParams({
	text: title,
	url: shareURL.href,
})}`;
---

<div class="share">
	<a
		class="share-button"
		href={xShareURL}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Xで共有"
	>
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path
				d="M18.9 2H22.2L14.9 10.3L23.5 22H16.8L11.5 15.1L5.5 22H2.2L10 13.1L1.7 2H8.6L13.3 8.2L18.9 2ZM17.7 19.9H19.5L7.6 4H5.7L17.7 19.9Z"
			></path>
		</svg>
	</a>
	<div class="share-control">
		<button
			class="share-button"
			type="button"
			aria-label="記事URLをコピー"
			aria-describedby={tooltipId}
			popovertarget={tooltipId}
			data-share-button
		>
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path
					d="M10.59 13.41C11 13.8 11 14.45 10.59 14.84C10.2 15.23 9.56 15.23 9.17 14.84C7.22 12.89 7.22 9.73 9.17 7.78L12.71 4.24C14.66 2.29 17.82 2.29 19.77 4.24S21.72 9.36 19.77 11.31L18.29 12.79C18.31 11.96 18.17 11.14 17.86 10.38L18.35 9.9C19.52 8.73 19.52 6.83 18.35 5.66C17.18 4.49 15.28 4.49 14.11 5.66L10.59 9.19C9.42 10.36 9.42 12.26 10.59 13.41M13.41 9.16C13.8 8.77 14.44 8.77 14.83 9.16C16.78 11.11 16.78 14.27 14.83 16.22L11.29 19.76C9.34 21.71 6.18 21.71 4.23 19.76S2.28 14.64 4.23 12.69L5.71 11.21C5.69 12.04 5.83 12.86 6.14 13.62L5.65 14.1C4.48 15.27 4.48 17.17 5.65 18.34C6.82 19.51 8.72 19.51 9.89 18.34L13.41 14.81C14.58 13.64 14.58 11.74 13.41 10.59C13 10.2 13 9.55 13.41 9.16Z"
				></path>
			</svg>
		</button>
		<Tooltip id={tooltipId} text="URLをクリップボードに保存しました" />
	</div>
</div>

<script>
	document.querySelectorAll<HTMLButtonElement>('[data-share-button]').forEach((button) => {
		const tooltipId = button.getAttribute('popovertarget');
		const tooltip = tooltipId ? document.getElementById(tooltipId) : null;
		let timer: number | undefined;

		button.addEventListener('click', async () => {
			const canonicalURL = document.querySelector('link[rel="canonical"]')?.href;
			const shareURL = canonicalURL || window.location.href;

			if (!navigator.clipboard?.writeText) return;

			try {
				await navigator.clipboard.writeText(shareURL);
			} catch {
				return;
			}

			if (!tooltip) return;

			window.clearTimeout(timer);
			if (!tooltip.matches(':popover-open')) {
				tooltip.showPopover();
			}
			timer = window.setTimeout(() => {
				if (tooltip.matches(':popover-open')) {
					tooltip.hidePopover();
				}
			}, 2200);
		});
	});
</script>

<style>
	.share {
		display: flex;
		gap: 12px;
		justify-content: flex-end;
		align-items: center;
		margin-top: 56px;
	}
	.share-control {
		position: relative;
	}
	.share-button {
		display: grid;
		place-items: center;
		width: 32px;
		height: 32px;
		padding: 0;
		border: 0;
		background: transparent;
		color: rgb(var(--gray));
		cursor: pointer;
		text-decoration: none;
	}
	.share-button:hover {
		color: rgb(var(--black));
	}
	.share-button:focus-visible {
		outline: 3px solid rgba(var(--gray), 0.32);
		outline-offset: 3px;
	}
	.share-button svg {
		width: 32px;
		height: 32px;
		fill: currentColor;
	}
</style>
