---
interface Props {
	id: string;
	text: string;
}

const { id, text } = Astro.props;
---

<span id={id} class="tooltip" role="status" aria-live="polite" hidden>{text}</span>

<style>
	.tooltip {
		position: absolute;
		right: 0;
		bottom: calc(100% + 10px);
		z-index: 1;
		width: max-content;
		max-width: min(280px, calc(100vw - 48px));
		padding: 8px 10px;
		border-radius: 4px;
		background: rgb(var(--black));
		color: var(--bg);
		font-size: 13px;
		font-weight: 700;
		line-height: 1.5;
		box-shadow: 0 8px 24px rgba(var(--gray-dark), 0.18);
	}
	.tooltip[hidden] {
		display: none;
	}
	.tooltip::after {
		position: absolute;
		right: 12px;
		bottom: -5px;
		width: 10px;
		height: 10px;
		background: inherit;
		content: '';
		transform: rotate(45deg);
	}
</style>
