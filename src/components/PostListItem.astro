---
import FormattedDate from './FormattedDate.astro';

interface Props {
	id: string;
	title: string;
	pubDate: Date;
}

const { id, title, pubDate } = Astro.props;
---

<li>
	<a class="post-link" href={`/blog/${id}/`}>
		<span class="title">{title}</span>
		<span class="date">
			<FormattedDate date={pubDate} />
		</span>
	</a>
</li>

<style>
	li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.post-link {
		display: block;
		padding: 0.8em 0;
		border-radius: 4px;
		color: inherit;
		text-decoration: none !important;
		transition: background-color var(--transition-hover);
	}
	.post-link:hover {
		background-color: #ededed;
		color: inherit;
		text-decoration: none !important;
	}
	.post-link:visited,
	.post-link:focus {
		color: inherit;
		text-decoration: none !important;
	}
	.title {
		display: block;
		color: rgb(var(--gray-dark));
		font-weight: 500;
		text-decoration: none;
	}
	.date {
		display: block;
		margin-top: 4px;
		color: rgb(var(--gray));
		font-size: 12px;
		text-decoration: none;
	}
</style>
