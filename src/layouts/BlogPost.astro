---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareButton from '../components/ShareButton.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagLink from '../components/TagLink.astro';

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, tags = [], headings = [] } = Astro.props;
const hasTableOfContents = headings.some((heading) => heading.depth === 2);
---

<html lang="ja">
	<head>
		<BaseHead
			title={title}
			description={description}
			imageAlt={`${title} | gamine.blog`}
			type="article"
			publishedTime={pubDate}
			modifiedTime={updatedDate}
			tags={tags}
		/>
		<style>
			html {
				background: var(--bg);
			}
			main {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: 0;
			}
			.page-frame {
				min-height: 100vh;
				background: var(--bg);
				transition: transform 0.24s ease;
			}
			.article-shell {
				display: grid;
				grid-template-columns: minmax(180px, 240px) minmax(0, 720px);
				gap: 48px;
				width: min(100% - 64px, 1008px);
				margin: auto;
				padding: 48px 0;
			}
			.toc-desktop {
				position: sticky;
				top: 96px;
				align-self: start;
				padding-top: 4px;
			}
			.toc-mobile {
				display: none;
			}
			.mobile-page-underlay {
				display: none;
			}
			.mobile-toc-toggle {
				display: none;
			}
			.prose {
				width: 100%;
				min-width: 0;
				color: rgb(var(--gray-dark));
				font-size: 18px;
			}
			.title {
				margin-bottom: 2rem;
				padding: 0 0 1rem;
				text-align: left;
				line-height: 1.4;
			}
			.title h1 {
				margin: 0;
				font-size: 32px;
				line-height: 1.4;
			}
			.date {
				margin-top: 4px;
				color: rgb(var(--gray));
				font-size: 12px;
				line-height: 1.4;
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				justify-content: flex-start;
				margin-top: 1rem;
			}
			.prose :global(h2) {
				scroll-margin-top: 112px;
				padding-bottom: 0.35rem;
				border-bottom: 1px solid rgba(var(--gray), 0.35);
				font-size: 24px;
			}
			.prose :global(h3) {
				font-size: 22px;
			}
			.prose :global(h4) {
				font-size: 20px;
			}
			.prose :global(h5) {
				font-size: 18px;
			}
			.prose :global(h6) {
				font-size: 16px;
			}
			.prose :global(pre),
			.prose :global(.astro-code) {
				border: 1px solid rgba(var(--gray), 0.2);
			}
			.prose :global(blockquote) {
				border-left-color: rgb(var(--gray));
			}
			@media (max-width: 960px) {
				.article-shell {
					display: block;
					width: calc(100% - 32px);
					padding: 16px 0;
				}
				.page-frame {
					position: relative;
					z-index: 3;
				}
				body.is-mobile-toc-open .page-frame,
				body.is-mobile-toc-open .mobile-page-underlay {
					transform: translateX(min(80vw, 320px));
				}
				body.is-mobile-toc-open .page-frame {
					box-shadow: -12px 0 32px rgba(var(--gray-dark), 0.28);
				}
				.toc-desktop {
					display: none;
				}
				.mobile-page-underlay {
					position: fixed;
					inset: 0;
					z-index: 2;
					display: block;
					background: var(--bg);
					transition: transform 0.24s ease;
					pointer-events: none;
				}
				.toc-mobile {
					display: block;
					position: fixed;
					top: 0;
					bottom: 0;
					left: 0;
					z-index: 1;
					width: min(80vw, 320px);
					box-sizing: border-box;
					overflow-y: auto;
					padding: 24px 20px;
					background: var(--brand);
					color: var(--bg);
					overscroll-behavior: contain;
				}
				.toc-mobile :global(.toc),
				.toc-mobile :global(.toc summary),
				.toc-mobile :global(.toc a) {
					color: var(--bg);
				}
				.toc-mobile :global(.toc a:hover) {
					background-color: rgba(250, 248, 241, 0.16);
					box-shadow: 0 0 0 4px rgba(250, 248, 241, 0.16);
					color: var(--bg);
				}
				.toc-mobile :global(.toc a.is-active) {
					background-color: var(--bg);
					box-shadow: 0 0 0 4px var(--bg);
					color: var(--brand);
				}
				.mobile-toc-toggle {
					position: fixed;
					right: 16px;
					bottom: calc(24px + env(safe-area-inset-bottom));
					z-index: 13;
					display: grid;
					place-items: center;
					width: 48px;
					height: 48px;
					padding: 0;
					border: 1px solid rgba(var(--gray), 0.24);
					border-radius: 8px;
					background: var(--bg);
					color: rgb(var(--gray-dark));
					box-shadow: 0 4px 12px rgba(var(--gray), 0.12);
					cursor: pointer;
				}
				.mobile-toc-toggle svg {
					width: 22px;
					height: 22px;
					fill: none;
					stroke: currentColor;
					stroke-linecap: round;
					stroke-linejoin: round;
					stroke-width: 2;
				}
				.mobile-toc-toggle-close {
					display: none;
				}
				body.is-mobile-toc-open .mobile-toc-toggle-menu {
					display: none;
				}
				body.is-mobile-toc-open .mobile-toc-toggle-close {
					display: block;
				}
				.mobile-toc-toggle:focus-visible {
					outline: 3px solid rgba(var(--gray), 0.32);
					outline-offset: 3px;
				}
				.prose {
					font-size: 16px;
				}
				.title h1 {
					font-size: 24px;
				}
				@media (prefers-reduced-motion: reduce) {
					.page-frame,
					.mobile-page-underlay {
						transition: none;
					}
				}
			}
		</style>
	</head>

	<body>
		{
			hasTableOfContents && (
				<aside class="toc-mobile" id="mobile-toc-panel" aria-label="モバイル目次">
					<TableOfContents headings={headings} />
				</aside>
			)
		}
		{hasTableOfContents && <div class="mobile-page-underlay" aria-hidden="true" />}
		{
			hasTableOfContents && (
				<button
					class="mobile-toc-toggle"
					type="button"
					aria-label="目次を開く"
					aria-controls="mobile-toc-panel"
					aria-expanded="false"
					data-mobile-toc-toggle
				>
					<svg class="mobile-toc-toggle-menu" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M4 6h16" />
						<path d="M4 12h16" />
						<path d="M4 18h10" />
					</svg>
					<svg class="mobile-toc-toggle-close" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M18 6 6 18" />
						<path d="m6 6 12 12" />
					</svg>
				</button>
			)
		}
		<div class="page-frame">
			<Header />
			<main>
				<article data-pagefind-body>
					<div class="article-shell">
						<aside class="toc-desktop">
							<TableOfContents headings={headings} />
						</aside>
						<div class="prose">
							<div class="title">
								<h1>{title}</h1>
								<div class="date">
									<FormattedDate date={pubDate} />
									{
										updatedDate && (
											<div class="last-updated-on">
												Last updated on <FormattedDate date={updatedDate} />
											</div>
										)
									}
								</div>
								{
									tags.length > 0 && (
										<div class="tags">
											{tags.map((tag) => (
												<TagLink tag={tag} />
											))}
										</div>
									)
								}
							</div>
							<slot />
							<ShareButton title={title} />
						</div>
					</div>
				</article>
			</main>
			<Footer />
		</div>
		<script>
			const tocToggle = document.querySelector<HTMLButtonElement>('[data-mobile-toc-toggle]');
			const mobileToc = document.getElementById('mobile-toc-panel');
			const pageFrame = document.querySelector<HTMLElement>('.page-frame');
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

			const setMobileTocState = (isOpen: boolean) => {
				document.body.classList.toggle('is-mobile-toc-open', isOpen);
				tocToggle?.setAttribute('aria-expanded', String(isOpen));
				tocToggle?.setAttribute('aria-label', isOpen ? '目次を閉じる' : '目次を開く');
				mobileToc?.setAttribute('aria-hidden', String(!isOpen));
			};

			const afterMobileTocClose = (callback: () => void) => {
				if (!pageFrame || reduceMotion.matches) {
					callback();
					return;
				}

				const finish = () => {
					window.clearTimeout(timer);
					pageFrame.removeEventListener('transitionend', finish);
					callback();
				};

				pageFrame.addEventListener('transitionend', finish);
				const timer = window.setTimeout(finish, 300);
			};

			const openMobileToc = () => {
				setMobileTocState(true);
			};

			const closeMobileToc = (callback?: () => void) => {
				if (!document.body.classList.contains('is-mobile-toc-open')) {
					callback?.();
					return;
				}

				setMobileTocState(false);
				afterMobileTocClose(() => {
					callback?.();
				});
			};

			mobileToc?.setAttribute('aria-hidden', 'true');

			tocToggle?.addEventListener('click', () => {
				if (document.body.classList.contains('is-mobile-toc-open')) {
					closeMobileToc();
					return;
				}

				openMobileToc();
			});

			mobileToc?.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', (event) => {
					const targetId = decodeURIComponent(link.hash.slice(1));
					const target = targetId ? document.getElementById(targetId) : null;

					if (!target) {
						closeMobileToc();
						return;
					}

					event.preventDefault();
					target.scrollIntoView({ block: 'start' });
					history.pushState(null, '', link.hash);
					closeMobileToc();
				});
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeMobileToc();
				}
			});
		</script>
	</body>
</html>
